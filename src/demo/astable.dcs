-93-93 0 0 250 0 0 250z" transform="matrix(1 0 0 -1 0 850)"></path></svg></a></div><div class="modebar-group"><a rel="tooltip" class="modebar-btn" data-title="Show closest data on hover" data-attr="hovermode" data-val="closest" data-toggle="false" data-gravity="ne"><svg viewBox="0 0 1500 1000" class="icon" height="1em" width="1em"><path d="m375 725l0 0-375-375 375-374 0-1 1125 0 0 750-1125 0z" transform="matrix(1 0 0 -1 0 850)"></path></svg></a><a rel="tooltip" class="modebar-btn active" data-title="Compare data on hover" data-attr="hovermode" data-val="x" data-toggle="false" data-gravity="ne"><svg viewBox="0 0 1125 1000" class="icon" height="1em" width="1em"><path d="m187 786l0 2-187-188 188-187 0 0 937 0 0 373-938 0z m0-499l0 1-187-188 188-188 0 0 937 0 0 376-938-1z" transform="matrix(1 0 0 -1 0 850)"></path></svg></a></div></div></div><svg class="main-svg" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="646.6666666666667" height="383.33333333333337"><g class="hoverlayer"></g></svg></div></div></div></foreignObject></g><text class="draggable" name="text" x="191" y="193" r="0" rtemp="0" transform="rotate(0 191 193)" style="fill: rgb(24, 36, 205); font-weight: bold; font-style: normal; font-size: 12px; font-family: normal;">out1</text><text class="draggable" name="text" x="486" y="188" r="0" rtemp="0" transform="rotate(0 486 188)" style="fill: rgb(205, 24, 78); font-weight: bold; font-style: normal; font-size: 12px; font-family: normal;">out2</text><g transform="translate(556,47)" x="556" y="47" title="codeHTML" width="502" height="551" class="codeHTML" name="codeHTML" rot="0"><foreignObject x="0" y="0" width="222" height="200" style="height: 551px; width: 836.667px;"><div name="htmlCode" style="zoom: 60%; height: 551px; width: 836.667px;" code="<div class=&quot;ch&quot;>
    
    <h1>Transistor Astable Multivibrator - SPICE Time Domain Analysis</h1>

    <div class=&quot;ch-card&quot;>
        <h2>Circuit Components</h2>
        <ul>
            <li><strong>Transistors (Q1, Q2):</strong> 2N2222 NPN</li>
            <li><strong>Resistors:</strong> R1, R2 = 2 kΩ (collector), R3, R4 = 100 kΩ (base)</li>
            <li><strong>Capacitors:</strong> C1, C2 = 0.01 μF (coupling)</li>
            <li><strong>Power Supply:</strong> V1 = 15V DC</li>
            <li><strong>Outputs:</strong> out1 and out2 (complementary square waves)</li>
        </ul>
    </div>

    <h2>Oscillation Frequency</h2>
    <div class=&quot;ch-formula&quot;>
        T = 0.693 × (R3 × C1 + R4 × C2) = 0.693 × (100k × 0.01μF + 100k × 0.01μF) = <strong>1.386 ms</strong><br>
        f = 1/T ≈ <strong>721 Hz</strong>
    </div>

    <h2>Simulation Results</h2>
    <div class=&quot;ch-grid&quot;>

        <div class=&quot;ch-col blue&quot;>
            <h3>Time Domain Response (Blue: V(out1))</h3>
            <ul>
                <li>Generates square wave with approximately 50% duty cycle</li>
                <li>Voltage swings between 0V (off) and ~14V (on)</li>
                <li>Period = 1.4 ms (matches theoretical calculation)</li>
                <li>Transistor Q2 is ON when V(out1) is high</li>
                <li>Complementary output to V(out2)</li>
            </ul>
        </div>

        <div class=&quot;ch-col red&quot;>
            <h3>Time Domain Response (Red: V(out2))</h3>
            <ul>
                <li>Generates square wave 180° out of phase with V(out1)</li>
                <li>When V(out1) is high, V(out2) is low, and vice versa</li>
                <li>Transistor Q1 is ON when V(out2) is high</li>
                <li>Perfect complementary operation (no overlap)</li>
                <li>Stable oscillation pattern with consistent period</li>
            </ul>
        </div>

    </div>

    <div class=&quot;ch-card green-border&quot;>
        <h2>Conclusion</h2>
        <p style=&quot;line-height: 1.6; margin: 0;&quot;>This circuit functions as an <strong>astable multivibrator</strong> (free-running oscillator). It alternates between two states without requiring an external trigger. The capacitors (C1, C2) charge through the base resistors (R3, R4), causing the transistors to switch states. When one transistor is ON, it rapidly turns the other OFF through the coupling capacitor, creating a continuous oscillation. The outputs (out1 and out2) provide complementary square waves at approximately 720 Hz. This circuit is commonly used for clock generation, LED flashers, and simple timing applications.</p>
    </div>

    <div class=&quot;ch-card&quot; style=&quot;background-color: #e8f8f5; border-left: 4px solid #1abc9c;&quot;>
        <h2 style=&quot;color: #16a085;&quot;>Operating Principle</h2>
        <ul style=&quot;line-height: 1.6; margin: 0;&quot;>
            <li><strong>Initial State:</strong> One transistor (e.g., Q1) turns on slightly faster than Q2</li>
            <li><strong>Capacitor Charging:</strong> C1 charges through R3, eventually turning on Q2</li>
            <li><strong>State Switching:</strong> When Q2 turns on, it discharges C2 through Q2's collector</li>
            <li><strong>Cycle Continues:</strong> The process repeats in the opposite direction</li>
            <li><strong>Frequency Control:</strong> Determined by R3/R4 and C1/C2 values</li>
        </ul>
    </div>

</div>"><div class="ch">
    
    <h1>Transistor Astable Multivibrator - SPICE Time Domain Analysis</h1>

    <div class="ch-card">
        <h2>Circuit Components</h2>
        <ul>
            <li><strong>Transistors (Q1, Q2):</strong> 2N2222 NPN</li>
            <li><strong>Resistors:</strong> R1, R2 = 2 kΩ (collector), R3, R4 = 100 kΩ (base)</li>
            <li><strong>Capacitors:</strong> C1, C2 = 0.01 μF (coupling)</li>
            <li><strong>Power Supply:</strong> V1 = 15V DC</li>
            <li><strong>Outputs:</strong> out1 and out2 (complementary square waves)</li>
        </ul>
    </div>

    <h2>Oscillation Frequency</h2>
    <div class="ch-formula">
        T = 0.693 × (R3 × C1 + R4 × C2) = 0.693 × (100k × 0.01μF + 100k × 0.01μF) = <strong>1.386 ms</strong><br>
        f = 1/T ≈ <strong>721 Hz</strong>
    </div>

    <h2>Simulation Results</h2>
    <div class="ch-grid">

        <div class="ch-col blue">
            <h3>Time Domain Response (Blue: V(out1))</h3>
            <ul>
                <li>Generates square wave with approximately 50% duty cycle</li>
                <li>Voltage swings between 0V (off) and ~14V (on)</li>
                <li>Period = 1.4 ms (matches theoretical calculation)</li>
                <li>Transistor Q2 is ON when V(out1) is high</li>
                <li>Complementary output to V(out2)</li>
            </ul>
        </div>

        <div class="ch-col red">
            <h3>Time Domain Response (Red: V(out2))</h3>
            <ul>
                <li>Generates square wave 180° out of phase with V(out1)</li>
                <li>When V(out1) is high, V(out2) is low, and vice versa</li>
                <li>Transistor Q1 is ON when V(out2) is high</li>
                <li>Perfect complementary operation (no overlap)</li>
                <li>Stable oscillation pattern with consistent period</li>
            </ul>
        </div>

    </div>

    <div class="ch-card green-border">
        <h2>Conclusion</h2>
        <p style="line-height: 1.6; margin: 0;">This circuit functions as an <strong>astable multivibrator</strong> (free-running oscillator). It alternates between two states without requiring an external trigger. The capacitors (C1, C2) charge through the base resistors (R3, R4), causing the transistors to switch states. When one transistor is ON, it rapidly turns the other OFF through the coupling capacitor, creating a continuous oscillation. The outputs (out1 and out2) provide complementary square waves at approximately 720 Hz. This circuit is commonly used for clock generation, LED flashers, and simple timing applications.</p>
    </div>

    <div class="ch-card" style="background-color: #e8f8f5; border-left: 4px solid #1abc9c;">
        <h2 style="color: #16a085;">Operating Principle</h2>
        <ul style="line-height: 1.6; margin: 0;">
            <li><strong>Initial State:</strong> One transistor (e.g., Q1) turns on slightly faster than Q2</li>
            <li><strong>Capacitor Charging:</strong> C1 charges through R3, eventually turning on Q2</li>
            <li><strong>State Switching:</strong> When Q2 turns on, it discharges C2 through Q2's collector</li>
            <li><strong>Cycle Continues:</strong> The process repeats in the opposite direction</li>
            <li><strong>Frequency Control:</strong> Determined by R3/R4 and C1/C2 values</li>
        </ul>
    </div>

</div></div></foreignObject></g>