: rgb(17, 162, 41); font-size: 10px; font-family: &quot;Times New Roman&quot;;" show="Value only" paramname="L" paramvalue="10mH">10mH</text></g><polyline points="165,30 135,30 135,30 " class="polyline" name="net" xdir="false" ref="N04" parent="false" parentcolor="false" used="true" id="4" node0="-1" node1="-1" style="stroke: rgb(0, 0, 0); fill: none; stroke-width: 1px;"></polyline>